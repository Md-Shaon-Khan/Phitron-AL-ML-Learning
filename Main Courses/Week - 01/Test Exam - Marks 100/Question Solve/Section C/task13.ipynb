   "source": [
    "numbers = list(map(int,input().split()))\n",
    "\n",
    "for i in range(len(numbers) - 1):\n",
    "  for j in range(len(numbers) - i - 1):\n",
    "    if numbers[j] > numbers[j+1]:\n",
    "      numbers[j+1], numbers[j] = numbers[j], numbers[j+1]\n",
    "      \n",
    "print(numbers)"
   ]
  }
