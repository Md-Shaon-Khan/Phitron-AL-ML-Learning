     "text": [
      "Year 2020 is a leap year.\n"
     ]
    }
   ],
   "source": [
    "year = int(input(\"Enter a year: \").strip())\n",
    "\n",
    "if year % 400 == 0:\n",
    "  print(f\"Year {year} is a leap year.\")\n",
    "elif year % 4 == 0 and year % 100 != 0:\n",
    "  print(f\"Year {year} is a leap year.\")\n",
    "else:\n",
    "  print(\"Not a leap year.\")"
   ]
  }
 ],
