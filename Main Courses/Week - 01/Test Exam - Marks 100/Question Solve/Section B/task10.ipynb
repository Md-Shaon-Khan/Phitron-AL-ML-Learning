   ],
   "source": [
    "number = int(input())\n",
    "\n",
    "number = str(number)\n",
    "\n",
    "number_lst = list(number)\n",
    "\n",
    "n = len(number_lst)\n",
    "n1 = n\n",
    "i = 0\n",
    "count = 0\n",
    "while i < (n//2):\n",
    "  if(number_lst[i] != number_lst[n1-1]):\n",
    "    count += 1\n",
    "    print(\"Not Palindrome\")\n",
    "    break\n",
    "  i += 1\n",
    "  n1 -= 1 \n",
    "if count == 0:\n",
    "  print(\"Palindrome\")"
   ]
  }
 ],
