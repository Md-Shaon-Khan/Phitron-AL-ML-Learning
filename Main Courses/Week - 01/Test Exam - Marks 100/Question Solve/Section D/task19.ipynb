   ],
   "source": [
    "numbers = list(map(int, input().split()))\n",
    "\n",
    "result = {\"even\": [], \"odd\": []}\n",
    "\n",
    "for num in numbers:\n",
    "    if num % 2 == 0:\n",
    "        result[\"even\"].append(num)\n",
    "    else:\n",
    "        result[\"odd\"].append(num)\n",
    "\n",
    "print(result)"
   ]
  }
