   "source": [
    "string = input()\n",
    "\n",
    "string_list = list(string)\n",
    "\n",
    "dictionary = {}\n",
    "\n",
    "for i in string_list:\n",
    "  if i not in dictionary.keys():\n",
    "    dictionary[i] = 1\n",
    "  else:\n",
    "    dictionary[i] = dictionary[i] + 1\n",
    "    \n",
    "for i in dictionary.keys():\n",
    "  if dictionary[i] > 1:\n",
    "    print(i,end=\"\")"
   ]
  }
