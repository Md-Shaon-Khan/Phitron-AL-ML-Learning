    "list1 = list(map(float,input().split()))\n",
    "\n",
    "avg = sum(list1) / len(list1)\n",
    "\n",
    "if avg < 85:\n",
    "    print(\"Dark Image\")\n",
    "elif 85<=avg<=170:\n",
    "    print(\"Normal Image\")\n",
    "else:\n",
    "    print(\"Bright Image\")"
   ]
