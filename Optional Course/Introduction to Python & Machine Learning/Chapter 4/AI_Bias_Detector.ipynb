   "source": [
    "list1 = input().split()\n",
    "\n",
    "countA = sum(s.count(\"A\") for s in list1)\n",
    "countB = sum(s.count(\"B\") for s in list1)\n",
    "\n",
    "countAp = (countA / len(list1)) * 100\n",
    "countBp = (countB / len(list1)) * 100\n",
    "\n",
    "if countAp > 70 or countBp > 70:\n",
    "    print(\"Biased Model\")\n",
    "else:\n",
    "    print(\"Fair Model\")"
   ]
  }
 ],
