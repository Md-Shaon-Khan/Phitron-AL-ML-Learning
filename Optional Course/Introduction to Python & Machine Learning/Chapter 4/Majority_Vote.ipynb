   "source": [
    "n = int(input())\n",
    "\n",
    "yes = 0\n",
    "no = 0\n",
    "for i in range(n):\n",
    "    vote = input()\n",
    "    if vote == \"YES\":\n",
    "        yes += 1\n",
    "    else:\n",
    "        no += 1\n",
    "\n",
    "if yes >= no:\n",
    "    print(\"ACCEPT\")\n",
    "else:\n",
    "    print(\"REJECT\")"
   ]
  }
 ],
