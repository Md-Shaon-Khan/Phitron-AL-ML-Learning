   "source": [
    "n = int(input())\n",
    "\n",
    "for _ in range(n):\n",
    "    num = int(input())\n",
    "\n",
    "    if num == 0:\n",
    "        print(0)\n",
    "        continue\n",
    "\n",
    "    digits = []\n",
    "    while num > 0:\n",
    "        digits.append(num % 10)\n",
    "        num //= 10\n",
    "\n",
    "    print(*digits)\n"
   ]
  }
 ],
