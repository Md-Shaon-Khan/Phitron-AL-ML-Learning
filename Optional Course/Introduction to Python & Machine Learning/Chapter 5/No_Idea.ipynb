   "source": [
    "n, m = map(int, input().split())\n",
    "\n",
    "arr = list(map(int, input().split()))\n",
    "A = set(map(int, input().split()))\n",
    "B = set(map(int, input().split()))\n",
    "\n",
    "happy = 0\n",
    "\n",
    "for x in arr:\n",
    "    if x in A:\n",
    "        happy += 1\n",
    "    if x in B:\n",
    "        happy -= 1\n",
    "\n",
    "print(happy)"
   ]
