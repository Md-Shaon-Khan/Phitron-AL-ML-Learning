    "import numpy as np\n",
    "\n",
    "arr = np.array(['cat', 'dog', 'fish'])\n",
    "\n",
    "\n",
    "print(np.char.upper(arr)) \n",
    "\n",
    "\n",
    "print(np.char.add(arr, '_animal'))\n",
    "\n",
    "\n",
    "print(np.char.str_len(arr))  \n",
    "\n",
    "\n",
    "arr_bytes = arr.astype('S')\n",
    "print(arr_bytes)"
   ]
